---
// Header component - Pagni & Golegã
// Paleta: Azul Naval + Prata

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Sobre', href: '/sobre' },
  { label: 'Áreas de Atuação', href: '/areas-de-atuacao' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contato', href: '/contato' },
]

const currentPath = Astro.url.pathname
---

<header class="bg-white border-b border-slate-200 sticky top-0 z-50">
  <nav class="max-w-6xl mx-auto px-4 py-4">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3">
        <img
          src="/images/pg.jpg"
          alt="Pagni & Golegã"
          class="h-12 w-12 rounded-md object-cover"
        />
        <div class="hidden sm:block">
          <span class="text-xl font-serif font-bold text-[#1a2a5e]">
            Pagni & Golegã
          </span>
          <span class="block text-xs text-slate-500">
            Consultoria Jurídica e Advocacia
          </span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <ul class="hidden lg:flex items-center gap-8">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                'text-sm font-medium transition-colors hover:text-[#1a2a5e]',
                currentPath === item.href
                  ? 'text-[#1a2a5e] border-b-2 border-[#1a2a5e] pb-1'
                  : 'text-slate-600',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- CTA Button (Desktop) -->
      <a
        href="/contato"
        class="hidden lg:inline-flex items-center gap-2 bg-[#1a2a5e] hover:bg-[#2d3a6e] text-white text-sm font-medium px-5 py-2.5 rounded-lg transition-colors"
      >
        Fale Conosco
      </a>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-slate-600 hover:text-[#1a2a5e] transition-colors"
        aria-label="Abrir menu"
        aria-expanded="false"
      >
        <svg id="menu-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden lg:hidden mt-4 pb-4 border-t border-slate-200 pt-4">
      <ul class="space-y-3">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                'block py-2 text-base font-medium transition-colors hover:text-[#1a2a5e]',
                currentPath === item.href ? 'text-[#1a2a5e]' : 'text-slate-600',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))}
        <li class="pt-3">
          <a
            href="/contato"
            class="block w-full text-center bg-[#1a2a5e] hover:bg-[#2d3a6e] text-white font-medium px-5 py-3 rounded-lg transition-colors"
          >
            Fale Conosco
          </a>
        </li>
      </ul>
    </div>
  </nav>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn')
  const mobileMenu = document.getElementById('mobile-menu')
  const menuIcon = document.getElementById('menu-icon')
  const closeIcon = document.getElementById('close-icon')

  menuBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden')

    mobileMenu?.classList.toggle('hidden')
    menuIcon?.classList.toggle('hidden')
    closeIcon?.classList.toggle('hidden')

    menuBtn?.setAttribute('aria-expanded', String(!isOpen))
  })
</script>
