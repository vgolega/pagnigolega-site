---
import Base from '../../layouts/Base.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
)

function formatDate(date: Date) {
  return date.toLocaleDateString('pt-BR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  })
}
---

<Base title="Blog" description="Artigos e publicações jurídicas do escritório Pagni & Golegã. Conteúdo sobre Direito de Família, Sucessões, Saúde, Consumidor e mais.">
  <Header />

  <main class="flex-1">
    <!-- Hero -->
    <section class="bg-gradient-to-br from-[#1a2a5e] to-[#2d3a6e] text-white py-10 md:py-14">
      <div class="max-w-6xl mx-auto px-4">
        <h1 class="text-4xl md:text-5xl font-serif font-bold mb-4">
          Blog
        </h1>
        <p class="text-xl text-slate-300 max-w-2xl">
          Artigos e publicações jurídicas para informar e esclarecer dúvidas sobre diversas áreas do Direito.
        </p>
      </div>
    </section>

    <!-- Posts -->
    <section class="py-16 md:py-24 bg-white">
      <div class="max-w-6xl mx-auto px-4">
        {posts.length === 0 ? (
          <div class="text-center py-12">
            <p class="text-slate-600 text-lg mb-6">
              Nenhum artigo publicado ainda.
            </p>
            <a
              href="/"
              class="inline-flex items-center gap-2 text-[#1a2a5e] hover:text-[#2d3a6e] font-semibold transition-colors"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
              </svg>
              Voltar ao início
            </a>
          </div>
        ) : (
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {posts.map((post) => (
              <article class="bg-white border border-slate-200 rounded-xl overflow-hidden hover:shadow-lg hover:border-[#1a2a5e] transition-all group">
                <a href={`/blog/${post.id}`} class="block p-6">
                  <div class="flex items-center gap-2 text-sm text-slate-500 mb-3">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {formatDate(post.data.pubDate)}
                    </time>
                    {post.data.tags && post.data.tags.length > 0 && (
                      <>
                        <span>•</span>
                        <span>{post.data.tags[0]}</span>
                      </>
                    )}
                  </div>
                  <h2 class="text-xl font-serif font-semibold text-slate-900 mb-3 group-hover:text-[#1a2a5e] transition-colors line-clamp-2">
                    {post.data.title}
                  </h2>
                  <p class="text-slate-600 line-clamp-3 mb-4">
                    {post.data.description}
                  </p>
                  <span class="inline-flex items-center gap-1 text-[#1a2a5e] font-medium text-sm group-hover:gap-2 transition-all">
                    Ler artigo
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </span>
                </a>
              </article>
            ))}
          </div>
        )}
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-slate-50">
      <div class="max-w-4xl mx-auto px-4 text-center">
        <h2 class="text-2xl font-serif font-bold text-slate-900 mb-4">
          Tem alguma dúvida jurídica?
        </h2>
        <p class="text-slate-600 mb-6">
          Entre em contato conosco para uma consulta personalizada.
        </p>
        <a
          href="/contato"
          class="inline-flex items-center justify-center bg-[#1a2a5e] hover:bg-[#2d3a6e] text-white font-semibold px-8 py-4 rounded-lg transition-colors"
        >
          Entre em Contato
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
