---
import Base from '../layouts/Base.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'

const areas = [
  {
    title: 'Família e Sucessões',
    description: 'Atuamos em questões familiares e sucessórias com sensibilidade e profissionalismo.',
    services: [
      'Divórcio consensual e litigioso',
      'Guarda e regulamentação de visitas',
      'Pensão alimentícia',
      'Inventário e partilha de bens',
      'Testamentos',
      'União estável',
    ],
  },
  {
    title: 'Planejamento Sucessório',
    description: 'Estratégias jurídicas para proteção e transmissão do patrimônio familiar.',
    services: [
      'Holding familiar',
      'Doação com reserva de usufruto',
      'Testamentos e codicilos',
      'Planejamento tributário sucessório',
      'Proteção patrimonial',
      'Pactos antenupciais',
    ],
  },
  {
    title: 'Direito à Saúde',
    description: 'Defesa dos direitos dos pacientes frente a planos de saúde e sistema de saúde.',
    services: [
      'Negativas de cobertura',
      'Reajustes abusivos',
      'Medicamentos e tratamentos',
      'Cirurgias e procedimentos',
      'Home care',
      'Internações',
    ],
  },
  {
    title: 'Direito do Consumidor',
    description: 'Proteção dos direitos nas relações de consumo.',
    services: [
      'Cobranças indevidas',
      'Contratos abusivos',
      'Vícios de produtos e serviços',
      'Negativação indevida',
      'Compras online',
      'Serviços bancários',
    ],
  },
  {
    title: 'Direito Trabalhista',
    description: 'Defesa dos direitos do trabalhador em todas as fases da relação de emprego.',
    services: [
      'Rescisão contratual',
      'Verbas trabalhistas',
      'Horas extras',
      'Assédio moral e sexual',
      'Acidente de trabalho',
      'Reconhecimento de vínculo',
    ],
  },
  {
    title: 'Direito Criminal',
    description: 'Defesa técnica em processos criminais com zelo e dedicação.',
    services: [
      'Defesa criminal',
      'Habeas corpus',
      'Audiências de custódia',
      'Recursos criminais',
      'Execução penal',
      'Acompanhamento em inquéritos',
    ],
  },
]

const whatsappNumber = '5511937305492'
---

<Base title="Áreas de Atuação" description="Conheça as áreas de atuação do escritório Pagni & Golegã: Família, Sucessões, Saúde, Consumidor, Trabalhista e Criminal.">
  <Header />

  <main class="flex-1">
    <!-- Hero -->
    <section class="bg-gradient-to-br from-[#1a2a5e] to-[#2d3a6e] text-white py-16 md:py-24">
      <div class="max-w-6xl mx-auto px-4">
        <h1 class="text-4xl md:text-5xl font-serif font-bold mb-4">
          Áreas de Atuação
        </h1>
        <p class="text-xl text-slate-300 max-w-2xl">
          Oferecemos assessoria jurídica especializada em diversas áreas do Direito,
          sempre com atendimento personalizado.
        </p>
      </div>
    </section>

    <!-- Areas -->
    <section class="py-16 md:py-24 bg-white">
      <div class="max-w-6xl mx-auto px-4">
        <div class="space-y-16">
          {areas.map((area, index) => (
            <div class={`grid md:grid-cols-2 gap-10 items-start ${index % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
              <div class={index % 2 === 1 ? 'md:order-2' : ''}>
                <h2 class="text-2xl md:text-3xl font-serif font-bold text-slate-900 mb-4">
                  {area.title}
                </h2>
                <div class="w-12 h-1 bg-[#9ca3af] mb-6"></div>
                <p class="text-lg text-slate-600 mb-6">
                  {area.description}
                </p>
                <a
                  href={`https://wa.me/${whatsappNumber}?text=${encodeURIComponent(`Olá! Vim pelo site e gostaria de mais informações sobre ${area.title}.`)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-[#1a2a5e] hover:text-[#2d3a6e] font-semibold transition-colors"
                >
                  Fale conosco sobre {area.title.toLowerCase()}
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              </div>
              <div class={`bg-slate-50 rounded-xl p-8 ${index % 2 === 1 ? 'md:order-1' : ''}`}>
                <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-500 mb-4">
                  Serviços
                </h3>
                <ul class="space-y-3">
                  {area.services.map((service) => (
                    <li class="flex items-start gap-3">
                      <svg class="w-5 h-5 text-[#1a2a5e] mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      <span class="text-slate-700">{service}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 md:py-24 bg-slate-50">
      <div class="max-w-4xl mx-auto px-4 text-center">
        <h2 class="text-3xl font-serif font-bold text-slate-900 mb-6">
          Não encontrou sua área?
        </h2>
        <p class="text-lg text-slate-600 mb-8">
          Entre em contato conosco. Podemos ajudá-lo ou indicar um profissional especializado.
        </p>
        <a
          href="/contato"
          class="inline-flex items-center justify-center bg-[#1a2a5e] hover:bg-[#2d3a6e] text-white font-semibold px-8 py-4 rounded-lg transition-colors"
        >
          Entre em Contato
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Base>
