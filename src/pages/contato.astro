---
import Base from '../layouts/Base.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'

const whatsappNumber = '5511937305492'
const whatsappMessage = encodeURIComponent('Olá! Vim pelo site e gostaria de mais informações.')
const whatsappLink = `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`

const areas = [
  'Família e Sucessões',
  'Planejamento Sucessório',
  'Direito à Saúde',
  'Consumidor',
  'Trabalhista',
  'Criminal',
  'Outro',
]
---

<Base title="Contato" description="Entre em contato com o escritório Pagni & Golegã. Atendimento via WhatsApp e formulário de contato.">
  <Header />

  <main class="flex-1">
    <!-- Hero -->
    <section class="bg-gradient-to-br from-[#1a2a5e] to-[#2d3a6e] text-white py-10 md:py-14">
      <div class="max-w-6xl mx-auto px-4">
        <h1 class="text-4xl md:text-5xl font-serif font-bold mb-4">
          Entre em Contato
        </h1>
        <p class="text-xl text-slate-300 max-w-2xl">
          Estamos à disposição para atendê-lo. Escolha a forma de contato que preferir.
        </p>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="py-16 md:py-24 bg-white">
      <div class="max-w-6xl mx-auto px-4">
        <div class="grid lg:grid-cols-2 gap-12">
          <!-- Contact Info -->
          <div>
            <h2 class="text-2xl font-serif font-bold text-slate-900 mb-6">
              Fale Conosco
            </h2>
            <div class="w-12 h-1 bg-[#9ca3af] mb-8"></div>

            <p class="text-slate-600 mb-8 leading-relaxed">
              Para um atendimento mais ágil, recomendamos o contato via WhatsApp.
              Você também pode preencher o formulário ao lado que entraremos em contato.
            </p>

            <!-- WhatsApp -->
            <div class="bg-green-50 border border-green-200 rounded-xl p-6 mb-8">
              <h3 class="text-lg font-semibold text-slate-900 mb-2">
                WhatsApp (Recomendado)
              </h3>
              <p class="text-slate-600 mb-4">
                Atendimento rápido e direto.
              </p>
              <a
                href={whatsappLink}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white font-semibold px-6 py-3 rounded-lg transition-colors"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                Iniciar Conversa
              </a>
            </div>

            <!-- Location -->
            <div class="bg-slate-50 rounded-xl p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-4">
                Localização
              </h3>
              <div class="flex items-start gap-3 text-slate-600">
                <svg class="w-5 h-5 text-[#1a2a5e] mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <div>
                  <p class="font-medium text-slate-900">São Paulo, SP</p>
                  <p class="text-sm">Atendimento em todo o Estado de São Paulo</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Contact Form -->
          <div class="bg-slate-50 rounded-2xl p-8">
            <h2 class="text-2xl font-serif font-bold text-slate-900 mb-6">
              Formulário de Contato
            </h2>

            <form
              action="https://formspree.io/f/YOUR_FORM_ID"
              method="POST"
              class="space-y-5"
            >
              <div>
                <label for="name" class="block text-sm font-medium text-slate-700 mb-1">
                  Nome completo *
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-[#1a2a5e] focus:border-transparent outline-none transition-shadow"
                  placeholder="Seu nome"
                />
              </div>

              <div class="grid md:grid-cols-2 gap-5">
                <div>
                  <label for="email" class="block text-sm font-medium text-slate-700 mb-1">
                    E-mail *
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-[#1a2a5e] focus:border-transparent outline-none transition-shadow"
                    placeholder="seu@email.com"
                  />
                </div>

                <div>
                  <label for="phone" class="block text-sm font-medium text-slate-700 mb-1">
                    Telefone
                  </label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-[#1a2a5e] focus:border-transparent outline-none transition-shadow"
                    placeholder="(11) 99999-9999"
                  />
                </div>
              </div>

              <div>
                <label for="area" class="block text-sm font-medium text-slate-700 mb-1">
                  Área de interesse
                </label>
                <select
                  id="area"
                  name="area"
                  class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-[#1a2a5e] focus:border-transparent outline-none transition-shadow bg-white"
                >
                  <option value="">Selecione uma área</option>
                  {areas.map((area) => (
                    <option value={area}>{area}</option>
                  ))}
                </select>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-slate-700 mb-1">
                  Mensagem *
                </label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="5"
                  class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-[#1a2a5e] focus:border-transparent outline-none transition-shadow resize-none"
                  placeholder="Descreva brevemente como podemos ajudá-lo..."
                ></textarea>
              </div>

              <div class="text-sm text-slate-500">
                <p>* Campos obrigatórios</p>
              </div>

              <button
                type="submit"
                class="w-full bg-[#1a2a5e] hover:bg-[#2d3a6e] text-white font-semibold py-4 rounded-lg transition-colors"
              >
                Enviar Mensagem
              </button>
            </form>

            <p class="text-xs text-slate-500 mt-4 text-center">
              Ao enviar, você concorda com nossa política de privacidade.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>
