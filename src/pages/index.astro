---
import Base from '../layouts/Base.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'

const areas = [
  {
    title: 'Família e Sucessões',
    description: 'Divórcio, guarda, inventário, partilha de bens e testamentos.',
    icon: 'family',
  },
  {
    title: 'Planejamento Sucessório',
    description: 'Holding familiar, doações, testamentos e proteção patrimonial.',
    icon: 'planning',
  },
  {
    title: 'Direito à Saúde',
    description: 'Planos de saúde, negativas de cobertura e tratamentos.',
    icon: 'health',
  },
  {
    title: 'Consumidor',
    description: 'Relações de consumo, contratos abusivos e cobranças indevidas.',
    icon: 'consumer',
  },
  {
    title: 'Trabalhista',
    description: 'Direitos do trabalhador, rescisões e verbas trabalhistas.',
    icon: 'work',
  },
  {
    title: 'Criminal',
    description: 'Defesa criminal, habeas corpus e acompanhamento processual.',
    icon: 'criminal',
  },
  {
    title: 'Serviços Extrajudiciais',
    description: 'Divórcio em cartório, reconhecimento de paternidade, pacto antenupcial e mais.',
    icon: 'extrajudicial',
  },
]

const whatsappNumber = '5511937305492'
const whatsappMessage = encodeURIComponent('Olá! Vim pelo site e gostaria de mais informações.')
const whatsappLink = `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`
---

<Base title="Home" description="Pagni & Golegã - Consultoria Jurídica e Advocacia. Atendimento especializado em Família, Sucessões, Saúde, Consumidor, Trabalhista e Criminal em São Paulo.">
  <Header />

  <main class="flex-1">
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-[#1a2a5e] to-[#2d3a6e] text-white py-20 md:py-32">
      <div class="max-w-6xl mx-auto px-4">
        <div class="max-w-3xl">
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-serif font-bold mb-4 leading-tight tracking-wide">
            Pagni & Golegã
          </h1>
          <p class="text-xl md:text-2xl text-slate-300 mb-4 font-serif">
            Consultoria Jurídica e Advocacia
          </p>
          <p class="text-lg text-slate-400 mb-8 max-w-xl">
            Atendimento especializado para pessoas físicas e jurídicas em todo o Estado de São Paulo.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href={whatsappLink}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 bg-white hover:bg-slate-100 text-[#1a2a5e] font-semibold px-8 py-4 rounded-lg transition-colors"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Fale pelo WhatsApp
            </a>
            <a
              href="/areas-de-atuacao"
              class="inline-flex items-center justify-center border-2 border-slate-400/40 hover:bg-white/10 text-white font-medium px-8 py-4 rounded-lg transition-colors"
            >
              Áreas de Atuação
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- About Preview -->
    <section class="py-20 md:py-28 bg-white">
      <div class="max-w-6xl mx-auto px-4">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="text-3xl md:text-4xl font-serif font-bold text-slate-900 mb-6">
              Sobre o Escritório
            </h2>
            <div class="w-16 h-1 bg-[#9ca3af] mb-6"></div>
            <p class="text-lg text-slate-600 mb-6 leading-relaxed">
              O escritório Pagni & Golegã oferece consultoria jurídica e advocacia com atendimento
              personalizado, buscando sempre as melhores soluções para cada caso.
            </p>
            <p class="text-slate-600 mb-8 leading-relaxed">
              Com atuação em diversas áreas do Direito, nosso compromisso é proporcionar
              segurança jurídica e resultados efetivos para nossos clientes.
            </p>
            <a
              href="/sobre"
              class="inline-flex items-center gap-2 text-[#1a2a5e] hover:text-[#2d3a6e] font-semibold transition-colors"
            >
              Conheça nossa história
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
          <div class="flex justify-center">
            <img
              src="/images/P&G.jpg"
              alt="Pagni & Golegã"
              class="max-w-sm w-full rounded-lg shadow-lg"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Areas -->
    <section class="py-20 md:py-28 bg-slate-50">
      <div class="max-w-6xl mx-auto px-4">
        <div class="text-center mb-14">
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-slate-900 mb-4">
            Áreas de Atuação
          </h2>
          <div class="w-16 h-1 bg-[#9ca3af] mx-auto mb-6"></div>
          <p class="text-lg text-slate-600 max-w-2xl mx-auto">
            Oferecemos assessoria jurídica especializada em diversas áreas do Direito.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {areas.map((area) => (
            <div class="bg-white p-8 rounded-xl border border-slate-200 hover:border-[#1a2a5e] hover:shadow-lg transition-all group">
              <h3 class="text-xl font-serif font-semibold text-slate-900 mb-3 group-hover:text-[#1a2a5e] transition-colors">
                {area.title}
              </h3>
              <p class="text-slate-600 leading-relaxed">
                {area.description}
              </p>
            </div>
          ))}
        </div>

        <div class="text-center mt-10">
          <a
            href="/areas-de-atuacao"
            class="inline-flex items-center gap-2 text-[#1a2a5e] hover:text-[#2d3a6e] font-semibold transition-colors"
          >
            Ver detalhes de cada área
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Blog Preview -->
    <section class="py-20 md:py-28 bg-white">
      <div class="max-w-6xl mx-auto px-4">
        <div class="text-center mb-14">
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-slate-900 mb-4">
            Artigos e Publicações
          </h2>
          <div class="w-16 h-1 bg-[#9ca3af] mx-auto mb-6"></div>
          <p class="text-lg text-slate-600 max-w-2xl mx-auto">
            Conteúdo jurídico produzido pelo escritório para informar e esclarecer dúvidas.
          </p>
        </div>

        <div class="text-center">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 bg-[#1a2a5e] hover:bg-[#2d3a6e] text-white font-medium px-8 py-4 rounded-lg transition-colors"
          >
            Acessar Blog
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 md:py-28 bg-[#1a2a5e] text-white">
      <div class="max-w-4xl mx-auto px-4 text-center">
        <h2 class="text-3xl md:text-4xl font-serif font-bold mb-6">
          Precisa de Assessoria Jurídica?
        </h2>
        <p class="text-xl text-slate-300 mb-10 max-w-2xl mx-auto">
          Entre em contato conosco. Teremos prazer em atendê-lo e encontrar a melhor solução para o seu caso.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href={whatsappLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 bg-green-600 hover:bg-green-700 text-white font-semibold px-8 py-4 rounded-lg transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>
          <a
            href="/contato"
            class="inline-flex items-center justify-center bg-white hover:bg-slate-100 text-[#1a2a5e] font-semibold px-8 py-4 rounded-lg transition-colors"
          >
            Formulário de Contato
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>
